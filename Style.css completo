/* ===============================
   HERO
================================ */

.hero{

    position:relative;
    min-height:100vh;

    display:flex;
    align-items:center;

    background:url("../img/banner/banner.jpg") center center/cover no-repeat;

}

.overlay{

    position:absolute;
    inset:0;

    background:linear-gradient(
        rgba(18,25,55,.72),
        rgba(18,25,55,.65)
    );

}

.hero-content{

    position:relative;
    z-index:2;
    color:#fff;

    max-width:700px;

}

.hero span{

    display:inline-block;

    background:rgba(255,255,255,.15);

    padding:10px 22px;

    border-radius:40px;

    margin-bottom:25px;

    backdrop-filter:blur(8px);

    font-weight:500;

}

.hero h1{

    font-size:3.8rem;

    line-height:1.15;

    margin-bottom:25px;

    font-weight:800;

}

.hero p{

    font-size:1.15rem;

    opacity:.95;

    line-height:1.8;

    margin-bottom:40px;

}

.hero-buttons{

    display:flex;

    gap:20px;

    flex-wrap:wrap;

}

/* ===============================
   TÍTULOS DAS SEÇÕES
================================ */

.titulo-secao{

    text-align:center;

    margin-bottom:60px;

}

.titulo-secao span{

    color:var(--primary);

    font-weight:600;

    text-transform:uppercase;

    letter-spacing:2px;

}

.titulo-secao h2{

    font-size:2.4rem;

    margin-top:12px;

    color:var(--text);

}

/* ===============================
   VANTAGENS
================================ */

.vantagens{

    padding:100px 0;

    background:#fff;

}

.cards-vantagens{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:30px;

}

.card-vantagem{

    background:#fff;

    border-radius:20px;

    padding:40px;

    text-align:center;

    box-shadow:var(--shadow);

    transition:.35s;

}

.card-vantagem:hover{

    transform:translateY(-10px);

}

.icone{

    width:85px;

    height:85px;

    margin:auto;

    margin-bottom:25px;

    border-radius:50%;

    background:var(--primary);

    color:#fff;

    display:flex;

    justify-content:center;

    align-items:center;

    font-size:34px;

}

.card-vantagem h3{

    margin-bottom:15px;

    font-size:1.3rem;

}

.card-vantagem p{

    color:var(--gray);

    line-height:1.7;

}
/* ===============================
   NÚMEROS
================================ */

.numeros{

    padding:100px 0;

    background:var(--primary);

    color:#fff;

}

.numeros-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:40px;

    text-align:center;

}

.numero h2{

    font-size:3.5rem;

    margin-bottom:15px;

    font-weight:800;

}

.numero p{

    font-size:1.1rem;

    opacity:.95;

}

/* ===============================
   PRODUTOS HOME
================================ */

.produtos-home{

    padding:100px 0;

    background:var(--secondary);

}

.cards-produtos{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));

    gap:35px;

}

.produto{

    background:#fff;

    border-radius:20px;

    overflow:hidden;

    box-shadow:var(--shadow);

    transition:.35s;

}

.produto:hover{

    transform:translateY(-10px);

}

.produto img{

    width:100%;

    height:260px;

    object-fit:cover;

}

.produto h3{

    font-size:1.4rem;

    margin:25px 25px 10px;

}

.produto p{

    margin:0 25px 25px;

    color:var(--gray);

    line-height:1.7;

}

.centro{

    text-align:center;

    margin-top:60px;

}

/* ===============================
   SOBRE HOME
================================ */

.sobre-home{

    padding:110px 0;

    background:#fff;

}

.sobre-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    align-items:center;

    gap:70px;

}

.sobre-grid span{

    color:var(--primary);

    font-weight:600;

    text-transform:uppercase;

    letter-spacing:2px;

}

.sobre-grid h2{

    font-size:2.6rem;

    margin:20px 0;

}

.sobre-grid p{

    color:var(--gray);

    line-height:1.9;

    margin-bottom:35px;

}

.sobre-grid img{

    width:100%;

    border-radius:20px;

    box-shadow:var(--shadow);

}

/* ===============================
   CTA
================================ */

.cta{

    padding:110px 0;

    background:linear-gradient(135deg,var(--primary),var(--primary-dark));

    color:#fff;

    text-align:center;

}

.cta h2{

    font-size:2.6rem;

    margin-bottom:20px;

}

.cta p{

    max-width:700px;

    margin:0 auto 40px;

    font-size:1.1rem;

    line-height:1.8;

}

    
