/* ==========================================
   ANIMATIONS.CSS
========================================== */

/* Elementos ocultos antes da animação */

.hidden{

    opacity:0;

    transform:translateY(60px);

    transition:opacity .8s ease, transform .8s ease;

}

/* Quando entram na tela */

.show{

    opacity:1;

    transform:translateY(0);

}

/* Fade */

@keyframes fadeIn{

    from{

        opacity:0;

    }

    to{

        opacity:1;

    }

}

/* Subindo */

@keyframes slideUp{

    from{

        opacity:0;

        transform:translateY(40px);

    }

    to{

        opacity:1;

        transform:translateY(0);

    }

}

/* Zoom */

@keyframes zoomIn{

    from{

        opacity:0;

        transform:scale(.9);

    }

    to{

        opacity:1;

        transform:scale(1);

    }

}

/* Hero */

.hero-content{

    animation:slideUp 1s ease;

}

/* Cards */

.card-vantagem{

    transition:.35s;

}

.card-vantagem:hover{

    transform:translateY(-10px) scale(1.02);

}

/* Produtos */

.produto{

    transition:.35s;

}

.produto:hover{

    transform:translateY(-10px);

}

/* Botões */

.btn-primary,
.btn-secondary,
.btn-header{

    transition:.3s;

}

.btn-primary:hover,
.btn-secondary:hover,
.btn-header:hover{

    transform:translateY(-3px);

}

/* WhatsApp */

.whatsapp{

    animation:fadeIn 1s ease;

}
