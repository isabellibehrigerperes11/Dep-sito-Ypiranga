.produtos-page{
    padding:80px 8%;
    background:#f7f9fc;
}

.titulo-pagina{
    text-align:center;
    margin-bottom:60px;
}

.titulo-pagina h1{
    font-size:3rem;
    color:#0B3D91;
}

.titulo-pagina p{
    color:#666;
    margin-top:10px;
}

.grid-produtos{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:35px;
}

.produto-card{
    background:white;
    border-radius:18px;
    overflow:hidden;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
    transition:.35s;
}

.produto-card:hover{
    transform:translateY(-10px);
    box-shadow:0 18px 40px rgba(0,0,0,.15);
}

.produto-card img{
    width:100%;
    height:250px;
    object-fit:cover;
}

.produto-card h3{
    padding:20px 20px 10px;
    color:#0B3D91;
}

.produto-card p{
    padding:0 20px 25px;
    color:#666;
    line-height:1.6;
}
